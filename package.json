{
  "name": "tidl",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "node build.js",
    "package": "npm run build && cd dist && zip -r ../tidl-$npm_package_version.zip .",
    "watch": "node build.js --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.300",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "msw": "^2.12.13",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@tidal-music/auth": "^1.6.0",
    "@tidal-music/common": "^0.2.0",
    "@tidal-music/player": "^0.17.0"
  }
}
